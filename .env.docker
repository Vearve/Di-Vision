# Local Docker settings (PostgreSQL in a local container)
PYTHONPATH=.
SECRET_KEY=django-insecure-local-docker
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_ENGINE=django.db.backends.postgresql
DB_HOST=ddr-postgres
DB_PORT=5432
DB_NAME=dailydrillreport_db
DB_USER=ddr_user
DB_PASSWORD=ddr_pass

# Optional auto superuser for local use
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123
